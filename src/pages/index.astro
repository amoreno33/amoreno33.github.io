---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter((p) => p.data.featured || p.data.status === 'coming-soon');
---

<BaseLayout title="Ing. Ana M Moreno — Portfolio">
  <!-- Hero -->
  <section class="mb-20">
    <p class="font-mono text-accent text-sm mb-3">Hola, soy</p>
    <h1 class="font-mono text-4xl sm:text-5xl font-bold text-text mb-4">Ing. Ana Moreno</h1>
    <p class="text-sm text-muted mb-8 font-mono tracking-wide">
      Backend Developer · Agentic AI · LLMs · RAG · Python · LangGraph · Azure
    </p>
    <a
      href="/blog"
      class="inline-block font-mono text-sm px-4 py-2 border border-accent text-accent hover:bg-accent hover:text-bg transition-colors rounded"
    >
      Leer el blog →
    </a>
  </section>

  <!-- Últimos posts -->
  {latestPosts.length > 0 && (
    <section class="mb-20">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-mono text-xs text-muted uppercase tracking-widest">Últimos posts</h2>
        <a href="/blog" class="text-xs font-mono text-muted hover:text-accent transition-colors">
          Ver todos →
        </a>
      </div>
      <div class="flex flex-col gap-3">
        {latestPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Proyectos -->
  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-mono text-xs text-muted uppercase tracking-widest">Proyectos</h2>
      <a href="/projects" class="text-xs font-mono text-muted hover:text-accent transition-colors">
        Ver todos →
      </a>
    </div>
    {featuredProjects.length > 0 ? (
      <div class="grid gap-3 sm:grid-cols-2">
        {featuredProjects.slice(0, 2).map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.body}
            stack={project.data.stack}
            github={project.data.github}
            demo={project.data.demo}
            status={project.data.status}
          />
        ))}
      </div>
    ) : (
      <div class="grid gap-3 sm:grid-cols-2">
        <ProjectCard
          title="Backend API"
          description=""
          stack={['Python', 'FastAPI']}
          status="coming-soon"
          comingSoonLabel="API REST con FastAPI y autenticación JWT. En construcción."
        />
        <ProjectCard
          title="LLM Agent"
          description=""
          stack={['LangChain', 'OpenAI']}
          status="coming-soon"
          comingSoonLabel="Agente conversacional con RAG sobre documentos. En construcción."
        />
      </div>
    )}
  </section>
</BaseLayout>
