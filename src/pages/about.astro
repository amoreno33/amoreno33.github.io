---
import BaseLayout from '@/layouts/BaseLayout.astro';

const timeline = [
  { year: '2023 — hoy', role: 'Python Developer (GenAI)', company: 'PI Data Strategy' },
  { year: '2023 — 2025', role: 'Jefe de Cátedra', company: 'UTN FRC' },
  { year: '2022 — 2024', role: 'Python Developer', company: 'Sardonyx SAS' },
  { year: '2021 — 2022', role: 'SR QA Engineer', company: 'Osana Salud' },
  { year: '2017 — 2025', role: 'Docente Investigadora', company: 'CINTRA · UTN FRC' },
  { year: '2015 — 2023', role: 'Docente (Adjunta / JTP)', company: 'UTN FRC' },
  { year: '2016 — 2020', role: 'Ingeniera en Automatismo', company: 'IPROIN SAS' },
  { year: '2013 — 2014', role: 'Software Developer', company: 'Clariphy' },
];

---

<BaseLayout title="About — Ing. Ana M Moreno" description="Ingeniera Electrónica especializada en backend con Python, soluciones cloud e IA aplicada.">
  <!-- Two-column: bio izquierda, foto derecha -->
  <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-12 items-start mb-16">

    <!-- Columna izquierda: bio -->
    <div class="space-y-5">
      <h1 class="font-mono text-3xl font-bold text-text">
        Hola, soy Ana Moreno
      </h1>

      <p class="text-muted leading-relaxed">
        Soy Ingeniera Electrónica especializada en desarrollo backend con Python.
      </p>

      <p class="text-muted leading-relaxed">
        Diseño e implemento soluciones productivas en la nube — participando end-to-end
        en diseño técnico, despliegues, escalado y observabilidad. Desarrollo soluciones
        de IA aplicada que resuelven problemas reales: desde agentes inteligentes hasta
        búsqueda semántica integrada a sistemas en producción.
      </p>

      <p class="text-muted leading-relaxed">
        Experiencia como referente técnico frente al cliente: traduzco requerimientos
        en soluciones y coordino entregas del equipo.
      </p>

      <p class="text-muted leading-relaxed">
        Lo que me define: aprendizaje continuo, criterio técnico propio y orientación al resultado.
      </p>

      <p class="font-mono text-sm text-accent pt-1">
        Python · FastAPI · Azure OpenAI · LangGraph · SQL / NoSQL
      </p>

